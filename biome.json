{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["src/**/*.ts", "__test__/**/*.ts"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": "off",
				"noUnknownPseudoClass": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noDoubleEquals": "warn"
			},
			"style": {
				"useConst": "warn"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.vue"],
			"linter": {
				"rules": {
					"recommended": true,
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					},
					"suspicious": {
						"noExplicitAny": "warn",
						"noDoubleEquals": "warn"
					},
					"style": {
						"useConst": "warn"
					}
				}
			},
			"formatter": {
				"enabled": false
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "none",
			"semicolons": "always"
		}
	},
	"html": {
		"formatter": {
			"enabled": true
		},
		"experimentalFullSupportEnabled": true
	}
}
