{
  "name": "vue-implant",
  "version": "1.0.1",
  "description": "A Vue 3 component injection framework for userscripts",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FlowingInk/vue-implant.git"
  },
  "homepage": "https://github.com/FlowingInk/vue-implant#readme",
  "bugs": {
    "url": "https://github.com/FlowingInk/vue-implant/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "injector",
    "component-injection",
    "userscript",
    "tampermonkey",
    "greasemonkey",
    "dom",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/vue-implant.umd.cjs",
  "types": "./dist/types/index.d.ts",
  "module": "./dist/vue-implant.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/vue-implant.js",
      "require": "./dist/vue-implant.umd.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "demo:dev": "vite --config vite.demo.config.ts",
    "demo:build": "vite build --config vite.demo.config.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:fix-unsafe": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "pinia": "^3.0.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-tsc": "^3.1.5"
  },
  "peerDependencies": {
    "pinia": "^2.0.0 || ^3.0.0",
    "vue": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "pinia": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
